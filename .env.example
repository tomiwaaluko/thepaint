# Database — Supabase direct connection (use for migrations and Railway services)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Redis — Upstash or Railway Redis add-on (set REDIS_URL from the add-on dashboard)
REDIS_URL=redis://localhost:6379/0

# Odds API — get key from the-odds-api.com
ODDS_API_KEY=your_key_here

# Gemini API - required for AI injury ingestion
# GEMINI_API_KEY=your_key_here

# MLflow — set to Railway MLflow service URL in production, or localhost for local dev
MLFLOW_TRACKING_URI=http://localhost:5000

# Logging
LOG_LEVEL=INFO

# nba_api disk cache (local only; Railway services use ephemeral storage)
NBA_API_CACHE_DIR=.cache/nba_api

# Slack alerts (optional — leave blank to disable)
SLACK_WEBHOOK_URL=

# CORS — comma-separated list of allowed origins for the FastAPI backend.
# Set to your Railway frontend URL in production, e.g.:
# ALLOWED_ORIGINS=https://chalk-frontend.up.railway.app,http://localhost:5173
# Leave as "*" to allow all origins (fine for public read-only APIs)
ALLOWED_ORIGINS=*
